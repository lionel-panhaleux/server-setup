---
extends: default

ignore: |
  .venv/
  .git/
  .ansible/
  uv.lock

rules:
  line-length:
    max: 160
    level: warning
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  document-start: disable
  truthy: disable
  indentation:
    spaces: consistent
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
